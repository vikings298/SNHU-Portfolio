<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF7FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="75dp">

            <TextView
                android:id="@+id/pageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="SMS Notifications"
                android:textSize="30sp"
                android:textStyle="bold"
                android:textColor="#101742" />

        </RelativeLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Receive text message alerts when you reach your goal weight."
            android:textAlignment="center"
            android:textSize="16sp"
            android:textColor="#4F5A70" />

        <!-- Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginTop="30dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Notification Type"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#101742" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Goal Weight Reached"
                android:textSize="18sp"
                android:textColor="#2F64E8"
                android:layout_marginTop="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="When your recorded weight is equal to or below your goal weight, the app can send an SMS notification."
                android:textSize="16sp"
                android:textColor="#5D667A"
                android:layout_marginTop="10dp" />

        </LinearLayout>

        <!-- Permission Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Permission Status"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#101742" />

            <TextView
                android:id="@+id/permissionStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SMS Permission: Not Granted"
                android:textSize="18sp"
                android:textColor="#D94A4A"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Request Permission Button -->
        <Button
            android:id="@+id/requestPermissionButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="25dp"
            android:text="Enable SMS Notifications"
            android:textStyle="bold"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2F64E8" />

        <!-- Example SMS Preview -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="20dp"
            android:layout_marginTop="25dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Example Notification"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#101742" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Congratulations! You have reached your goal weight of 160 lbs."
                android:textSize="16sp"
                android:textColor="#5D667A"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Bottom nav -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="85dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/bottom_nav_background"
            android:padding="8dp"
            android:layout_marginTop="25dp"
            android:layout_marginBottom="25dp">


            <!-- Progress -->
            <LinearLayout
                android:id="@+id/progressNav"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress"
                    android:textColor="#BFFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Home -->
            <LinearLayout
                android:id="@+id/homeNav"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Account -->
            <LinearLayout
                android:id="@+id/accountNav"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:background="@drawable/nav_selected"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤"
                    android:textSize="26sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Account"
                    android:textColor="#BFFFFFFF"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>